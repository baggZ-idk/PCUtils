<?xml version="1.0" encoding="utf-8" ?>
<Project>
    <Target Name="CopyToMods" AfterTargets="Build">
        <ItemGroup>
            <FilesToCopy Include="$(TargetPath)"/>
            <FilesToCopy Include="$(TargetDir)$(TargetName).pdb" Condition="Exists('$(TargetDir)$(TargetName).pdb')"/>
        </ItemGroup>

        <Copy SourceFiles="@(FilesToCopy)" DestinationFiles="@(FilesToCopy->'$(ModsPath)\%(Filename)%(Extension)')"/>
        <Message Text="Copied $(TargetFileName) and $(TargetName).pdb to Mods" Importance="high"/>
    </Target>
</Project>